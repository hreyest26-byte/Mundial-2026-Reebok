# ============================================================
# REEBOK WORLD CUP POOL 2026 — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local al repositorio
# ============================================================

# Supabase — https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# ⚠️ Service Role — SOLO para API Routes admin, NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# API-Football — https://rapidapi.com/api-sports/api/api-football
FOOTBALL_API_KEY=tu_rapidapi_key_aqui
FOOTBALL_API_HOST=v3.football.api-sports.io

# Resend — https://resend.com/api-keys
RESEND_API_KEY=tu_resend_key_aqui
RESEND_FROM_EMAIL=polla@reebok.cl

# URL de la app (localhost en dev, dominio real en producción)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token para autenticar Vercel Cron Jobs
# Generar con: openssl rand -hex 32
CRON_SECRET=tu_cron_secret_aqui

# Cloudinary (opcional — para avatares)
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret
